# CollabCode Environment Configuration — EXAMPLE
# =====================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit your .env file to git
# =====================================================

# URL of the code execution service
# Local dev  → http://localhost:8080  (run: cd cloud-executor && python main.py)
# Render     → https://collabcode-executor.onrender.com
CLOUD_RUN_URL=http://localhost:8080

# PostgreSQL Database URL (required for auth features)
# Local dev  → postgresql://postgres:password@localhost:5432/collabcode
# Render     → auto-injected from render.yaml "fromDatabase" binding
DATABASE_URL=

# JDoodle Compiler API Credentials
# Free tier: 200 executions/day | Sign up at https://www.jdoodle.com/compiler-api
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# Mistral AI API Key (powers the Codestral AI code helper)
# Get your key at https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
