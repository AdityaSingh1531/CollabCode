# JDoodle API Credentials
# You can get these by signing up at https://www.jdoodle.com/compiler-api
JDOODLE_CLIENT_ID=your_client_id_here
JDOODLE_CLIENT_SECRET=your_client_secret_here

# Server Configuration
PORT=8080

# CORS: Comma-separated list of allowed frontend origins.
# In production, set this to your deployed frontend URL.
# Example: ALLOWED_ORIGINS=https://collabcode-frontend.run.app
ALLOWED_ORIGINS=http://localhost:3000
